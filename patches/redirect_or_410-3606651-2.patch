 /**
@@ -60,7 +63,24 @@ function redirect_or_410_form_redirect_redirect_form_alter(&$form, \Drupal\Core\
  */
 function redirect_or_410_form_redirect_redirect_edit_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id): void {
   $form['status_code']['#options'][410] = t('410 Gone');
-  redirect_or_410_apply_redirect_widget_state($form, (int) $form['status_code']['#default_value']);
+  $input = $form_state->getUserInput();
