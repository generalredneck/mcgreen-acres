+  /**
+   * Tests the "manage simplenews hidden subscriptions" permission.
+   *
+   * Only users with this permission should be able to see and manage
+   * subscriptions to a "hidden" newsletter, whether from a user's own
+   * subscriptions page or from the subscriber admin forms. Users without it
+   * should not see the hidden newsletter in either place, matching the
+   * behavior for all other subscribers-facing forms.
+   *
+   * @see https://www.drupal.org/project/simplenews/issues/2111981
+   */
+  public function testHiddenNewsletterSubscriptionManagement() {
+    $hidden_newsletter = Newsletter::create([
+      'id' => 'hidden_test',
+      'name' => 'Hidden test newsletter',
+      'access' => 'hidden',
+    ]);
+    $hidden_newsletter->save();
+
+    $target_user = $this->drupalCreateUser(['subscribe to newsletters']);
+    Subscriber::create([
+      'mail' => $target_user->getEmail(),
+      'uid' => $target_user->id(),
+    ])->save();
+    $subscriber = Subscriber::loadByMail($target_user->getEmail());
+
+    $field_id = $this->getNewsletterFieldId('hidden_test');
+    $field_name = 'subscriptions[hidden_test]';
+
+    // An administrator without the new permission must not see or be able
+    // to manage the hidden newsletter, either from the account subscriptions
+    // page or from the subscriber admin forms.
+    $admin_user = $this->drupalCreateUser([
+      'administer simplenews subscriptions',
+    ]);
+    $this->drupalLogin($admin_user);
+
+    $this->drupalGet('user/' . $target_user->id() . '/simplenews');
+    $this->assertSession()->fieldNotExists($field_id);
+
+    $this->drupalGet('admin/people/simplenews/edit/' . $subscriber->id());
+    $this->assertSession()->fieldNotExists($field_id);
+
+    $this->drupalGet('admin/people/simplenews/create');
+    $this->assertSession()->fieldNotExists($field_id);
+
+    // Grant the new permission: the hidden newsletter should now appear,
+    // labeled as hidden, and be manageable from both forms.
+    $hidden_admin = $this->drupalCreateUser([
+      'administer simplenews subscriptions',
+      'manage simplenews hidden subscriptions',
+    ]);
+    $this->drupalLogin($hidden_admin);
+
+    $this->drupalGet('user/' . $target_user->id() . '/simplenews');
+    $this->assertSession()->fieldExists($field_id);
+    $this->assertSession()->pageTextContains('Hidden test newsletter (hidden)');
+    $this->assertSession()->checkboxNotChecked($field_id);
+
+    $this->submitForm([$field_name => TRUE], 'Save');
+    \Drupal::entityTypeManager()->getStorage('simplenews_subscriber')->resetCache();
+    $subscriber = Subscriber::loadByMail($target_user->getEmail());
+    $this->assertTrue($subscriber->isSubscribed('hidden_test'));
+
+    // The subscriber admin edit form should also show the hidden newsletter,
+    // reflect its current (now subscribed) state, and allow toggling it.
+    $this->drupalGet('admin/people/simplenews/edit/' . $subscriber->id());
+    $this->assertSession()->fieldExists($field_id);
+    $this->assertSession()->pageTextContains('Hidden test newsletter (hidden)');
+    $this->assertSession()->checkboxChecked($field_id);
+
+    $this->submitForm([$field_name => FALSE], 'Save');
+    \Drupal::entityTypeManager()->getStorage('simplenews_subscriber')->resetCache();
+    $subscriber = Subscriber::loadByMail($target_user->getEmail());
+    $this->assertTrue($subscriber->isUnsubscribed('hidden_test'));
+  }
+
 }
