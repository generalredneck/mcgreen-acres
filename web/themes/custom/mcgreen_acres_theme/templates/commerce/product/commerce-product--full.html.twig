{#
/**
 * @file
 *
 * Default product template.
 *
 * Available variables:
 * - attributes: HTML attributes for the wrapper.
 * - product: The rendered product fields.
 *   Use 'product' to print them all, or print a subset such as
 *   'product.title'. Use the following code to exclude the
 *   printing of a given field:
 *   @code
 *   {{ product|without('title') }}
 *   @endcode
 * - product_entity: The product entity.
 * - product_url: The product URL.
 *
 * @ingroup themeable
 */
#}

{%
  set classes = [
  'pb-4',
  'mb-5',
  'overflow-hidden'
]
%}

<article{{ attributes.addClass(classes) }}>
  <div class="row g-5">
    <div class="col-md-5">
      {% if product.variation_images|render is not empty %}
        {{- product.variation_images -}}
      {% else %}
        {{- product.images -}}
      {% endif %}
    </div>
    <div class="col-md-7">
      <div class="mb-2">
        {{- product.product_categories -}}
      </div>
      {{- product.brand -}}
      <div class="fs-4 font-weight-bold">{{- product.variation_price -}}</div>
      {% if farmstand_available %}
        <div class="fulfillment-status fulfillment-status--farmstand">{{ 'Available at the Farm Stand today'|t }}</div>
      {% else %}
        <div class="fulfillment-status fulfillment-status--appointment">{{ 'Pickup by appointment only'|t }}</div>
      {% endif %}
      <hr/>
      {% if product.special_categories|render is not empty %}
        <div class="mb-3">
          {{- product.special_categories -}}
        </div>
      {% endif %}
      {{- product.variations -}}
      {{- product.variation_stock -}}
      {% if farmstand_available %}
        <div class="alert alert-info"><p class="lead"><strong>Available at the Farm Stand — self serve, free to take upon purchase.</strong></p><p>Pickup only, at our address:<br><a href="https://maps.app.goo.gl/g27qR5a6KtSQ9XrS7" target="_blank" rel="noopener noreferrer">2414 Westmoreland Rd Red Oak, Texas 75154</a>. Not available for delivery or shipping.</p></div>
      {% else %}
        <div class="alert alert-info"><p class="lead"><strong>Orders must be picked up at the farm by appointment.</strong></p><p>We are located at:<br><a href="https://maps.app.goo.gl/g27qR5a6KtSQ9XrS7" target="_blank" rel="noopener noreferrer">2414 Westmoreland Rd Red Oak, Texas 75154</a></p></div>
      {% endif %}
      {{- product|without('variation_attributes', 'images', 'variation_images', 'title', 'variation_price', 'product_categories', 'brand', 'special_categories', 'variations', 'variation_stock') -}}
    </div>
  </div>

</article>
