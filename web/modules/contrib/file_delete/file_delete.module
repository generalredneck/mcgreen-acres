<?php

/**
 * @file
 * Contains file_delete.module.
 */

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\file_delete\Hook\FileDeleteHooks;
use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
#[LegacyHook]
function file_delete_help($route_name, RouteMatchInterface $route_match) {
  return \Drupal::service(FileDeleteHooks::class)->help($route_name, $route_match);
}

/**
 * Implements hook_entity_type_build().
 */
#[LegacyHook]
function file_delete_entity_type_build(array &$entity_types): void {
  \Drupal::service(FileDeleteHooks::class)->entityTypeBuild($entity_types);
}
