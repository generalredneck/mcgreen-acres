{
  "name": "varbase_bootstrap_paragraphs",
  "description": "Varbase Core provides the base configuration and shared modules for a Varbase site.",
  "license": "GPL-2.0-or-later",
  "private": true,
  "engines": {
    "yarn": ">= 4.9.3",
    "node": ">= 20.0"
  },
  "keywords": [
    "Drupal",
    "Varbase",
    "JSON API",
    "Open API"
  ],
  "author": "Vardot",
  "scripts": {
    "phpcs": "phpcs --standard=./.phpcs.xml .",
    "phpcbf": "phpcbf --standard=./.phpcs.xml .",
    "lint:yaml": "node ./node_modules/eslint/bin/eslint.js --config=.eslintrc.json --ext .yml .",
    "spellcheck": "cspell lint .",
    "test": "cucumber-js --config cucumber.js",
    "test:chromium": "BROWSER=chromium cucumber-js --config cucumber.js",
    "test:firefox": "BROWSER=firefox cucumber-js --config cucumber.js",
    "test:webkit": "BROWSER=webkit cucumber-js --config cucumber.js",
    "generate-reports": "generate-reports"
  },
  "dependencies": {
    "@cucumber/cucumber": "10.0.1",
    "@cucumber/pretty-formatter": "1.0.0",
    "playwright": "1.60.0",
    "slick-carousel": "^1.8",
    "tsx": "4.22.1",
    "webship-js": "~2.0.0"
  },
  "resolutions": {
    "@cucumber/cucumber": "10.0.1",
    "@cucumber/pretty-formatter": "1.0.0",
    "playwright": "1.60.0"
  },
  "devDependencies": {
    "cspell": "^8.16.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jquery": "^1.5.1",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-yml": "^1.18.0",
    "prettier": "^3.5.3"
  },
  "packageManager": "yarn@4.9.3"
}