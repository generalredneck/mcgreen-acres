{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "ignorePatterns": [
    "node_modules/**",
    "tests/**",
    "cucumber.js",
    "playwright.config.ts",
    "**/*.yml",
    "**/*.yaml"
  ]
}
