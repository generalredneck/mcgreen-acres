<?php

/**
 * @file
 * Sales chart module — provides an interactive revenue chart block.
 */

/**
 * Implements hook_theme().
 */
function sales_chart_theme(): array {
  return [
    'sales_chart' => [
      'variables' => [
        'stats' => [],
      ],
    ],
    'sales_chart_weekday' => [
      'variables' => [
        'stats' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_views_view().
 *
 * Injects the sales chart block into the monthly display between the exposed
 * form and the results by prepending to attachment_before.
 */
function sales_chart_preprocess_views_view(array &$variables): void {
  if ($variables['id'] == 'sales_report' && in_array($variables['display_id'], ['monthly', 'daily', 'weekly'])) {
    $block_view_builder = \Drupal::entityTypeManager()->getViewBuilder('block');
    $block_storage = \Drupal::entityTypeManager()->getStorage('block');

    $chart = NULL;
    if ($block = $block_storage->load('claro_saleschart')) {
      $chart = $block_view_builder->view($block);
    }

    // The day-of-week breakdown only makes sense next to the daily display.
    $weekday_chart = NULL;
    if ($variables['display_id'] === 'daily' && ($weekday_block = $block_storage->load('claro_saleschart_weekday'))) {
      $weekday_chart = $block_view_builder->view($weekday_block);
    }

    // Prepend the chart(s) ahead of any existing attachment_before content.
    $variables['attachment_before'] = [
      'sales_chart' => $chart,
      'sales_chart_weekday' => $weekday_chart,
      'existing'    => $variables['attachment_before'],
    ];
  }
}
