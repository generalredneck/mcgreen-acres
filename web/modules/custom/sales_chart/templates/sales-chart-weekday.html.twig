<div class="sales-chart-wrapper">
  <div class="sales-chart-stats">
    <div class="sales-chart-stat">
      <span class="sales-chart-stat__label">Busiest Day</span>
      <span class="sales-chart-stat__value">{{ stats.busiest_day }}</span>
    </div>
    <div class="sales-chart-stat">
      <span class="sales-chart-stat__label">Busiest Day Avg</span>
      <span class="sales-chart-stat__value">{{ stats.currency }} {{ stats.busiest_day_avg }}</span>
    </div>
    <div class="sales-chart-stat">
      <span class="sales-chart-stat__label">Days Analyzed</span>
      <span class="sales-chart-stat__value">{{ stats.days_analyzed }}</span>
    </div>
  </div>
  <div class="sales-chart-date-range">{{ stats.date_range }}</div>
  <div class="sales-chart-canvas-wrapper">
    <canvas id="sales-chart-weekday"></canvas>
  </div>
</div>
