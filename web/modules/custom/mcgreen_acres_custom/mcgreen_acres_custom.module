<?php

/**
 * @file
 * Contains mcgreen_acres_custom.module.
 */

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\user\UserInterface;

/**
 * Newsletter that all accounts should be auto-subscribed to.
 */
const MCGREEN_ACRES_CUSTOM_DEFAULT_NEWSLETTER = 'default';

/**
 * Implements hook_help().
 */
function mcgreen_acres_custom_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    // Main module help for the mcgreen_acres_custom module.
    case 'help.page.mcgreen_acres_custom':
      $output = '';
      $output .= '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('Custom functionality for McGreen Acres site.') . '</p>';
      return $output;

    default:
  }
}

/**
 * Implements hook_theme().
 */
function mcgreen_acres_custom_theme() {
  return [
    'mcgreen_acres_custom' => [
      'render element' => 'children',
    ],
    'search_block' => [
      'variables' => [
        'search_value' => '',
      ],
      'render element' => 'children',
    ],
  ];
}

/**
 * Implements hook_user_insert().
 *
 * Subscribes every new account to the default newsletter.
 */
function mcgreen_acres_custom_user_insert(UserInterface $account) {
  if ($account->getEmail()) {
    \Drupal::service('simplenews.subscription_manager')->subscribe(
      $account->getEmail(),
      MCGREEN_ACRES_CUSTOM_DEFAULT_NEWSLETTER,
      $account->getPreferredLangcode()
    );
  }
}

/**
 * Implements hook_user_update().
 *
 * Unsubscribes accounts from the default newsletter when they are blocked
 * or canceled (account cancellation sets the status to blocked before any
 * eventual deletion).
 */
function mcgreen_acres_custom_user_update(UserInterface $account) {
  $original = $account->original ?? NULL;
  if ($original && $original->isActive() && $account->isBlocked() && $account->getEmail()) {
    \Drupal::service('simplenews.subscription_manager')->unsubscribe(
      $account->getEmail(),
      MCGREEN_ACRES_CUSTOM_DEFAULT_NEWSLETTER
    );
  }
}

/**
 * Implements hook_user_delete().
 *
 * Unsubscribes accounts from the default newsletter when they are deleted.
 */
function mcgreen_acres_custom_user_delete(UserInterface $account) {
  if ($account->getEmail()) {
    \Drupal::service('simplenews.subscription_manager')->unsubscribe(
      $account->getEmail(),
      MCGREEN_ACRES_CUSTOM_DEFAULT_NEWSLETTER
    );
  }
}
