<?php

/**
 * @file
 */

use Drupal\commerce_order\Entity\OrderInterface;
use Drupal\Core\Ajax\AjaxResponse;
use Drupal\Core\Ajax\RedirectCommand;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Markup;
use Drupal\Core\Url;
use Drupal\mcgreen_acres_store\Form\FarmstandSettingsForm;
use Drupal\mcgreen_acres_store\Plugin\Commerce\Fee\CreditCardProcessingFee;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_commerce_order_create().
 *
 * Defaults "Cover Stripe fees" to off for orders created via the admin
 * "Create a new order" form (used for manually-entered cash orders), since
 * field_cover_stripe_fees' own field default (opted-in) is meant for
 * customer checkout, not staff-entered orders. Scoped to this specific route
 * rather than a role check, since the route already requires
 * "create commerce_order" access and this only needs to affect this one
 * entry point, not every order a staff member might otherwise touch.
 */
function mcgreen_acres_store_commerce_order_create(OrderInterface $order) {
  if (\Drupal::routeMatch()->getRouteName() === 'entity.commerce_order.add_page') {
    if ($order->hasField('field_cover_stripe_fees')) {
      $order->set('field_cover_stripe_fees', FALSE);
    }
    // Manually-entered orders (Zelle/cash/Square sales logged after the
    // fact) default to already fulfilled, since the owner is typically
    // entering the sale because it already happened. Explicitly set to
    // FALSE (rather than left empty) so OrderFulfillmentSubscriber treats
    // this as a deliberate choice instead of falling back to the
    // farmstand-availability check used for checkout orders; staff can
    // still flip it on the order form for the rare ahead-of-time sale.
    if ($order->hasField('field_needs_fulfillment')) {
      $order->set('field_needs_fulfillment', FALSE);
    }
  }
}

/**
 * Implements hook_module_implements_alter().
 */
function mcgreen_acres_store_module_implements_alter(&$implementations, $hook) {
  // Force our cart form alter to run after commerce_stripe's, since it needs
  // to remove the "stripe_express_checkout_buttons" element that
  // commerce_stripe_form_views_form_commerce_cart_form_default_alter()
  // injects, rather than relying on module name alphabetical ordering.
  if ($hook === 'form_views_form_commerce_cart_form_default_alter' && isset($implementations['mcgreen_acres_store'])) {
    $group = $implementations['mcgreen_acres_store'];
    unset($implementations['mcgreen_acres_store']);
    $implementations['mcgreen_acres_store'] = $group;
  }
}

/**
 *
 */
function mcgreen_acres_store_form_views_form_commerce_cart_form_default_alter(&$form, &$form_state, $form_id) {
  foreach ($form['remove_button'] as &$item) {
    if (is_array($item) && $item['#type'] == 'submit') {
      $item['#type'] = 'image_button';
      $item['#src'] = '/themes/custom/mcgreen_acres_theme/icons/trash.svg';
      $item['#alt'] = 'Remove';
      unset($item['#value']);
    }
  }
  // Define the "Continue Shopping" button as a link styled like a button.
  $form['actions']['continue_shopping'] = [
    '#type' => 'link',
    '#title' => t('Continue Shopping'),
    '#url' => Url::fromRoute('view.product_catalog.catalog_page'),
    '#attributes' => [
      'class' => ['button', 'button--continue-shopping', 'btn', 'btn-outline-primary'],
    ],
    '#weight' => -10,
  ];

  $order = _mcgreen_acres_store_get_cart_form_order($form_state);

  // A herd share (subscription product) can be purchased alongside physical
  // products in the same "default" cart order (both use the "physical_product"
  // order item type). Stripe Express Checkout skips the normal checkout flow
  // and its payment gateway selection, so it can't be allowed to pay for a
  // subscription; only the regular checkout's Stripe Payment Element pane
  // should handle that. The same applies to a cart that isn't fully
  // available at the farm stand: express checkout has no step in it to ask
  // "today or later?", so any cart requiring appointment fulfillment has to
  // go through the regular checkout flow instead. Remove the buttons
  // commerce_stripe just injected in both cases.
  if ($order && isset($form['stripe_express_checkout_buttons'])) {
    if (_mcgreen_acres_store_cart_has_subscription($order) || _mcgreen_acres_store_cart_needs_fulfillment($order)) {
      unset($form['stripe_express_checkout_buttons']);
    }
    else {
      // Show a blocking overlay from the moment the customer confirms
      // payment in the Apple Pay/Google Pay sheet until the browser
      // navigates away, since the checkout-return request that follows is
      // slow and would otherwise leave them looking at an unresponsive
      // cart page.
      $form['#attached']['library'][] = 'mcgreen_acres_store/express_checkout_overlay';

      // Without a label, the buttons just look like an unexplained stack of
      // buttons sitting above the "Support the Farm" checkbox and the
      // regular cart actions. Label them, so it's clear they're an
      // alternate, faster checkout path rather than part of the normal
      // cart controls.
      $form['stripe_express_checkout_buttons']['#prefix'] = '<div class="express-checkout-group"><p class="express-checkout-group__label">' . t('Express Checkout') . '</p><p class="express-checkout-group__caption">' . t('For picking up today at the Farm Stand') . '</p>';
      $form['stripe_express_checkout_buttons']['#suffix'] = '</div>';

      // The "ordering ahead" alternative is placed after the "Support the
      // Farm" checkbox (weight 60) rather than right under the express
      // buttons, so it reads as pointing at the Checkout button below it
      // rather than cluttering the express group itself.
      $form['express_checkout_ordering_ahead_notice'] = [
        '#markup' => '<p class="express-checkout-group__callout">' . t('Ordering ahead or need to schedule pickup? Use Checkout below.') . '</p>',
        '#weight' => 70,
      ];
    }
  }

  // Let the customer opt out of the "Support the Farm" contribution here,
  // before they can reach the Stripe Express Checkout buttons, which skip
  // the regular checkout flow (and its own opt-out checkbox) entirely.
  $order = _mcgreen_acres_store_get_cart_form_order($form_state);
  if ($order && $order->bundle() === 'default') {
    $subtotal = CreditCardProcessingFee::getSubtotalExcludingFee($order);
    if (!$subtotal->isZero()) {
      $cover_fees = $order->get('field_cover_stripe_fees')->value;
      $checked = ($cover_fees === NULL || (bool) $cover_fees);
      $fee_amount = CreditCardProcessingFee::calculateFee((float) $subtotal->getNumber());

      $form['cover_stripe_fees'] = [
        '#type' => 'checkbox',
        '#title' => t('Support the Farm (+@amount)', ['@amount' => '$' . number_format($fee_amount, 2)]),
        '#description' => t('100% optional. This helps offset the cost of accepting card payments.'),
        '#default_value' => $checked,
        // 60: renders after the view's own output (weight 50, which includes
        // the item rows and the Subtotal/Total footer area) but before the
        // actions buttons (weight 100, Drupal's default for #type actions).
        '#weight' => 60,
        '#ajax' => [
          'callback' => '_mcgreen_acres_store_cart_cover_fees_ajax',
          'progress' => ['type' => 'throbber', 'message' => NULL],
        ],
      ];
    }
  }
}

/**
 * Ajax callback for the cart page "Support the Farm" checkbox.
 *
 * Saves the opt-in/out choice to the cart order (which recalculates the fee
 * adjustment via order refresh) and reloads the page so the updated total is
 * visible, since the Views cart form isn't otherwise ajax-enabled.
 */
function _mcgreen_acres_store_cart_cover_fees_ajax(array $form, FormStateInterface $form_state): AjaxResponse {
  $order = _mcgreen_acres_store_get_cart_form_order($form_state);
  if ($order) {
    $order->set('field_cover_stripe_fees', (bool) $form_state->getValue('cover_stripe_fees'));
    $order->save();
  }
  $response = new AjaxResponse();
  $response->addCommand(new RedirectCommand(Url::fromRoute('commerce_cart.page')->toString()));
  return $response;
}

/**
 * Checks whether any order item's purchased entity is a subscription.
 */
function _mcgreen_acres_store_cart_has_subscription(OrderInterface $order): bool {
  foreach ($order->getItems() as $order_item) {
    $purchased_entity = $order_item->getPurchasedEntity();
    if ($purchased_entity && $purchased_entity->bundle() === 'subscription') {
      return TRUE;
    }
  }
  return FALSE;
}

/**
 * Checks whether an order needs appointment fulfillment rather than
 * immediate farm stand pickup.
 *
 * An order is considered fulfilled immediately only if every item in it is
 * available at the farm stand; a single item that isn't (e.g. a gift box,
 * vanilla, or livestock, which require an appointment) means the whole
 * order needs to be scheduled, since a customer buying a mixed cart is
 * already ordering ahead rather than standing at the stand.
 */
function _mcgreen_acres_store_cart_needs_fulfillment(OrderInterface $order): bool {
  if (\Drupal::state()->get(FarmstandSettingsForm::STATE_KEY, FALSE)) {
    return TRUE;
  }
  foreach ($order->getItems() as $order_item) {
    $purchased_entity = $order_item->getPurchasedEntity();
    if (!$purchased_entity instanceof \Drupal\commerce_product\Entity\ProductVariationInterface) {
      continue;
    }
    $product = $purchased_entity->getProduct();
    if (!$product || !$product->hasField('field_farmstand_available') || !$product->get('field_farmstand_available')->value) {
      return TRUE;
    }
  }
  return FALSE;
}

/**
 * Resolves whether an order needs fulfillment, preferring an explicit answer.
 *
 * field_needs_fulfillment is set explicitly either by the customer
 * (PickupTiming checkout pane, for a farm-stand-eligible cart) or by staff
 * (OrderNeedsFulfillmentForm, for a manually-entered order); either way,
 * that deliberate choice should win over composition. Only falls back to
 * _mcgreen_acres_store_cart_needs_fulfillment() when nothing has explicitly
 * answered yet.
 */
function _mcgreen_acres_store_order_needs_fulfillment(OrderInterface $order): bool {
  if ($order->hasField('field_needs_fulfillment') && !$order->get('field_needs_fulfillment')->isEmpty()) {
    return (bool) $order->get('field_needs_fulfillment')->value;
  }
  return _mcgreen_acres_store_cart_needs_fulfillment($order);
}

/**
 * Gets the order backing the current commerce_cart_form_default view.
 */
function _mcgreen_acres_store_get_cart_form_order(FormStateInterface $form_state): ?OrderInterface {
  $view = $form_state->getBuildInfo()['args'][0] ?? NULL;
  if (!$view instanceof ViewExecutable || empty($view->result)) {
    return NULL;
  }
  $entity = $view->result[0]->_entity ?? NULL;
  return $entity instanceof OrderInterface ? $entity : NULL;
}

/**
 * Implements hook_form_alter().
 */
function mcgreen_acres_store_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (str_starts_with($form_id, 'commerce_order_item_add_to_cart_form') && $form_state->get('view_mode') === 'teaser') {
    $form['quantity']['#access'] = FALSE;
  }

  // Remove options from the subscription cancel form so users can't cancel
  // immediately, only at the end of the billing cycle, unless they are admins.
  if ($form_id === 'commerce_subscription_product_variation_cancel_form') {
    $user = \Drupal::currentUser();
    /** @var \Drupal\user\Entity\User $user_entity */
    $user_entity = \Drupal::entityTypeManager()->getStorage('user')->load($user->id());
    $is_admin = $user_entity->hasRole('administrator');
    if (isset($form['cancel_option']['#options'])) {
      // Define the cancellation policy text.
      $cancellation_policy_text = '<p><strong>Cancellation Policy:</strong> You are canceling your subscription at the end of the current billing cycle. Per the herd share agreement, you are required to give written notice of cancellation. Upon cancellation here, reach out to us to arrange the offboarding of your share.</p>';

      // Add a new `#markup` element to the form array.
      // The weight property ensures the markup appears at the top.
      $form['cancellation_policy'] = [
        '#type' => 'markup',
        '#markup' => $cancellation_policy_text,
      // Use a negative weight to place it at the top of the form.
        '#weight' => -100,
      ];
      if (!$is_admin) {
        // Remove the 'now' option from the list of radio buttons.
        unset($form['cancel_option']['#options']['now']);
      }
    }
    // Remove the "Cancel immediately" button for non-admin users if a
    // cancellation is already scheduled.
    if (isset($form['actions']['submit']['#value'])) {
      $subscription = $form_state->getFormObject()->getEntity();
      if ($subscription->hasScheduledChange('state', 'canceled')) {
        if (!$is_admin) {
          unset($form['actions']['submit']);
        }
      }
    }
  }
}

/**
 * Implements hook_mail().
 */
function mcgreen_acres_store_mail($key, &$message, $params) {
  switch ($key) {
    case 'subscription_cancel_scheduled':
      $message['subject'] = $params['subject'];
      $message['body'][] = Markup::create($params['body']);
      break;
  }
}

/**
 *
 */
function mcgreen_acres_store_entity_update(EntityInterface $entity) {
  mcgreen_acres_store_entity_insert($entity);
}

/**
 * Implements hook_entity_insert().
 */
function mcgreen_acres_store_entity_insert(EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'commerce_product_variation') {
    /** @var \Drupal\search_api\Plugin\search_api\datasource\ContentEntityTrackingManager $tracking_manager */
    $search_api_tracking_manager = \Drupal::service('search_api.entity_datasource.tracking_manager');
    $product = $entity->get('product_id')->entity;
    $search_api_tracking_manager->trackEntityChange($product);
    $indexes = $search_api_tracking_manager->getIndexesForEntity($product);
    foreach ($indexes as $index) {
      if (!empty($indexes)) {
        $index->trackItemsUpdated($product->getEntityTypeId(), [$product->id() . ':' . $product->language()->getId()]);
        foreach ($index->getDatasourceIds() as $datasource_id) {
          $index->indexItems(-1, $datasource_id);
        }
      }
    }
  }
}

/**
 * Implements hook_preprocess_commerce_product__teaser().
 */
function mcgreen_acres_store_preprocess_commerce_product__teaser(&$variables) {
  /** @var \Drupal\commerce_product\Entity\ProductInterface $product */
  $product = $variables['product_entity'];
  if (!$product) {
    return;
  }

  $variables['farmstand_available'] = $product->hasField('field_farmstand_available')
    && (bool) $product->get('field_farmstand_available')->value
    && !\Drupal::state()->get(FarmstandSettingsForm::STATE_KEY, FALSE);
  // The state flag isn't a cache context/tag Drupal knows about on its own,
  // so without this the rendered teaser/full markup (and any Views row
  // cache built from it, e.g. the product catalog) would keep showing the
  // stale badge until an unrelated cache clear evicted it. Paired with the
  // invalidateTags() call in FarmstandSettingsForm::submitForm().
  $variables['#cache']['tags'][] = FarmstandSettingsForm::CACHE_TAG;
  $variables['is_subscription'] = $product->bundle() === 'subscription';

  $variations = $product->getVariations();
  $langcode = \Drupal::languageManager()->getCurrentLanguage()->getId();

  if (count($variations) === 1 && $product->bundle() === 'physical') {
    $variables['add_to_cart_form'] = [
      '#lazy_builder' => [
        'commerce_product.lazy_builders:addToCartForm', [
          $product->id(),
          'teaser',
          TRUE,
          $langcode,
        ],
      ],
      '#create_placeholder' => TRUE,
    ];
  }
  else {
    $stock_manager = \Drupal::service('commerce_stock.service_manager');
    $any_in_stock = FALSE;
    foreach ($variations as $variation) {
      if ($stock_manager->getStockLevel($variation) > 0) {
        $any_in_stock = TRUE;
        break;
      }
    }

    if ($any_in_stock) {
      $variables['choose_options_url'] = $product->toUrl();
    }
    else {
      $variables['all_out_of_stock'] = TRUE;
    }
  }
}

/**
 * Implements hook_preprocess_commerce_product__full().
 */
function mcgreen_acres_store_preprocess_commerce_product__full(&$variables) {
  /** @var \Drupal\commerce_product\Entity\ProductInterface $product */
  $product = $variables['product_entity'];
  if (!$product) {
    return;
  }

  $variables['farmstand_available'] = $product->hasField('field_farmstand_available')
    && (bool) $product->get('field_farmstand_available')->value
    && !\Drupal::state()->get(FarmstandSettingsForm::STATE_KEY, FALSE);
  // The state flag isn't a cache context/tag Drupal knows about on its own,
  // so without this the rendered teaser/full markup (and any Views row
  // cache built from it, e.g. the product catalog) would keep showing the
  // stale badge until an unrelated cache clear evicted it. Paired with the
  // invalidateTags() call in FarmstandSettingsForm::submitForm().
  $variables['#cache']['tags'][] = FarmstandSettingsForm::CACHE_TAG;
}

function mcgreen_acres_store_commerce_checkout_pane_info_alter(&$definitions) {
  if (!empty($definitions['customer_comments'])) {
    $definitions['customer_comments']['class'] = 'Drupal\mcgreen_acres_store\Plugin\Commerce\CheckoutPane\CustomerComments';
  }
  if (!empty($definitions['profile_form'])) {
    $definitions['profile_form']['class'] = 'Drupal\mcgreen_acres_store\Plugin\Commerce\CheckoutPane\CustomProfileForm';
  }
  if (!empty($definitions['completion_message'])) {
    $definitions['completion_message']['class'] = 'Drupal\mcgreen_acres_store\Plugin\Commerce\CheckoutPane\CompletionMessage';
  }
  if (!empty($definitions['custom_checkout_message'])) {
    $definitions['custom_checkout_message']['class'] = 'Drupal\mcgreen_acres_store\Plugin\Commerce\CheckoutPane\CustomCheckoutMessage';
  }
}
