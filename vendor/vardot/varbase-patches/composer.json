        "composer",
        "patches",
        "composer patches",
        "varbase",
        "varbase patches",
        "drupal",
        "drupal patches"
    ],
    "license": "GPL-2.0-or-later",
    "type": "composer-plugin",
    "authors": [
        {
            "name": "Vardot",
            "homepage": "https://www.drupal.org/vardot",
            "role": "Maintainer"
        }
    ],
